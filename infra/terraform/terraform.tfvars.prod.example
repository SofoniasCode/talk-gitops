# Copy to a prod-specific tfvars and fill in real values.
# Use: terraform apply -var-file=terraform.prod.tfvars

subscription_id         = "00000000-0000-0000-0000-000000000000"
location                = "westeurope"
environment             = "prod"
project                 = "talk"
domain                  = "example.com"
postgres_admin_username = "talkadmin"
postgres_admin_password = "CHANGE_ME_use_a_strong_password"
aks_node_count          = 3
aks_vm_size             = "Standard_D4s_v5"
