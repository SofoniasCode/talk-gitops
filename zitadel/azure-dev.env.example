# Copy this file locally before use, then replace placeholders.
# Do not commit real tokens, client secrets, or generated secret values.

# Zitadel API access. Set TALK_ZITADEL_ADMIN_PAT only in your shell or secret manager.
export TALK_ZITADEL_ISSUER="https://zitadel.dev.example.com"
export TALK_ZITADEL_API_URL="https://zitadel.dev.example.com"
# export TALK_ZITADEL_ADMIN_PAT="<zitadel-admin-personal-access-token>"

# Organization and project selection.
# Prefer TALK_ZITADEL_ORGANIZATION_ID once the cloud organization exists.
export TALK_ZITADEL_ORGANIZATION_NAME="ZITADEL"
# export TALK_ZITADEL_ORGANIZATION_ID="<zitadel-organization-id>"
export TALK_ZITADEL_PROJECT_NAME="Talk Management"

# oauth2-proxy OIDC app. This should be a production-like web app, not a local dev app.
export TALK_ZITADEL_OAUTH2_PROXY_APP_NAME="oauth2-proxy-dev"
export TALK_ZITADEL_OIDC_DEVELOPMENT_MODE="false"
export TALK_ZITADEL_REDIRECT_URIS="https://talk.dev.example.com/oauth2/callback"
export TALK_ZITADEL_POST_LOGOUT_URIS="https://talk.dev.example.com/"

# Use only if the app exists but the client secret was lost and must be rotated.
export TALK_ZITADEL_REGENERATE_CLIENT_SECRET="false"

# Optional if the action file moves.
export TALK_ZITADEL_ACTION_NAME="talk_roles_claim"
export TALK_ZITADEL_ACTION_SCRIPT="zitadel/actions/talk_roles_claim.js"
